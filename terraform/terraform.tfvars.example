folder_id = "b1gepvj6lg03dc9505kh"

postgresql_password = "change-me"
docker_oauth_token  = "change-me"

# Путь к yc CLI (для kubeconfig в формате yc get-credentials)
yc_cli_path = "/usr/local/bin/yc"
yc_profile  = "default"

# IP для доступа к API Kubernetes и SSH (CIDR /32)
# home_ip   = "YOUR.PUBLIC.IP/32"
# office_ip = "OFFICE.PUBLIC.IP/32"
